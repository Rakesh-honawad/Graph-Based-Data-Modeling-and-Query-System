# Copy this to .env and fill in your key(s)
# Pick ONE provider: gemini or groq

# ── Option A: Google Gemini (free at https://ai.google.dev) ──
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# ── Option B: Groq (free at https://console.groq.com) ──
# LLM_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here
